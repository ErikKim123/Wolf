# Design Ref: §10.3 — 환경변수 규약 (NEXT_PUBLIC_*=브라우저, 나머지=서버 전용)
# 실제 값은 .env 에 넣고 git 에 커밋하지 말 것 (.gitignore 처리됨)

# NOTE: 앱별 NEXT_PUBLIC_* 는 각 앱의 .env.local 에 둔다 (apps/web/.env.local, apps/admin/.env.local).
#       이 루트 .env 는 DB 검증/결제 등 모노레포 공용 서버 키 용도.

# --- Supabase (클라이언트 접근 가능 — 각 앱 .env.local 에도 필요) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
# 배포 도메인 (apps/web 의 sitemap/OG 기준)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# --- Supabase (서버 전용, RLS 우회 — 절대 NEXT_PUBLIC_ 금지) ---
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- 소셜/전화 로그인 (앱 env 불필요 — Supabase 대시보드에서 설정) ---
# 구글(OAuth): Supabase Dashboard > Authentication > Providers > Google 활성화.
#   - Google Cloud Console > OAuth 2.0 클라이언트 ID/시크릿 입력, 승인된 리디렉션 URI 에
#     https://YOUR-PROJECT.supabase.co/auth/v1/callback 등록.
# 카카오톡(OAuth): Supabase Dashboard > Authentication > Providers > Kakao 활성화.
#   - Kakao Developers 앱의 REST API 키/시크릿 입력, Redirect URI 에
#     https://YOUR-PROJECT.supabase.co/auth/v1/callback 등록.
#   - Supabase > Auth > URL Configuration > Redirect URLs 에
#     http://localhost:3000/**, https://your-domain.com/** 허용.
# WhatsApp(전화 OTP): Supabase Dashboard > Authentication > Providers > Phone 활성화.
#   - SMS provider = Twilio, Message channel 에서 WhatsApp 활성화(Twilio WhatsApp Sender 필요).
#   - 앱 코드는 signInWithOtp({ phone, options: { channel: 'whatsapp' } }) 로 호출.

# --- DB 직접 연결 (Runtime 검증 db:verify 용, postgres 직접 연결) ---
# Supabase: Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# --- AI 상품페이지 생성 (Phase 3) ---
# 실제 사용 위치는 apps/admin/.env.local (admin 의 /api/ai/* route handler). 서버 전용, 노출 금지.
ANTHROPIC_API_KEY=""

# --- 결제 (Phase 4, 서버 전용) ---
# Stripe(en/USD): Dashboard > Developers > API keys
STRIPE_SECRET_KEY=""
# Stripe webhook 서명검증: Dashboard > Developers > Webhooks > Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=""
# PortOne(ko/KRW) V2: 콘솔 > 결제연동 > V2 API secret
PORTONE_API_SECRET=""
# PortOne webhook 서명검증(선택): 콘솔 > 결제연동 > 웹훅 secret. 비워도 동작(서버가 PortOne API 로 재검증).
PORTONE_WEBHOOK_SECRET=""

# --- 결제 (브라우저 노출 — apps/web/.env.local 에도 필요) ---
# PortOne V2 storeId / 채널키(KRW 결제 채널). 콘솔 > 상점 설정 / 채널 관리.
NEXT_PUBLIC_PORTONE_STORE_ID=""
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=""
