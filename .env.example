# Design Ref: §10.3 — 환경변수 규약 (NEXT_PUBLIC_*=브라우저, 나머지=서버 전용)
# 실제 값은 .env 에 넣고 git 에 커밋하지 말 것 (.gitignore 처리됨)

# NOTE: 앱별 NEXT_PUBLIC_* 는 각 앱의 .env.local 에 둔다 (apps/web/.env.local, apps/admin/.env.local).
#       이 루트 .env 는 DB 검증/결제 등 모노레포 공용 서버 키 용도.

# --- Supabase (클라이언트 접근 가능 — 각 앱 .env.local 에도 필요) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
# 배포 도메인 (apps/web 의 sitemap/OG 기준)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# --- Supabase (서버 전용, RLS 우회 — 절대 NEXT_PUBLIC_ 금지) ---
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- DB 직접 연결 (Runtime 검증 db:verify 용, postgres 직접 연결) ---
# Supabase: Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# --- AI 상품페이지 생성 (Phase 3) ---
# 실제 사용 위치는 apps/admin/.env.local (admin 의 /api/ai/* route handler). 서버 전용, 노출 금지.
ANTHROPIC_API_KEY=""

# --- 결제 (Phase 4, 서버 전용 — 추후 연동) ---
STRIPE_SECRET_KEY=""
PORTONE_API_SECRET=""
